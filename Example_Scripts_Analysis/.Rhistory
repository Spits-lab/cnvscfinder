# ── Step 5: Run PCA ──────────────────────────────────────────────────────────
# metadata rownames must match matrix colnames
rownames(metadata) <- metadata$info
modvar <- PCAtools::pca(
mat_filtered,
metadata   = metadata,
removeVar  = 0.1      # remove bottom 10% variance genes
)
View(mat_filtered)
# ── Step 5: Run PCA ──────────────────────────────────────────────────────────
# metadata rownames must match matrix colnames
rownames(metadata) <- metadata$sample_name
modvar <- PCAtools::pca(
mat_filtered,
metadata   = metadata,
removeVar  = 0.1      # remove bottom 10% variance genes
)
colnames(count_matrix)
View(metadata)
# ── Step 5: Run PCA ──────────────────────────────────────────────────────────
# metadata rownames must match matrix colnames
metadata <- metadata[match(metadata$sample_name, colnames(mat_filtered)),]
View(mat_filtered)
match(colnames(mat_filtered),metadata$sample_name)
# ── Step 5: Run PCA ──────────────────────────────────────────────────────────
# metadata rownames must match matrix colnames
metadata <- metadata[match(colnames(mat_filtered),metadata$sample_name),]
View(metadata)
modvar <- PCAtools::pca(
mat_filtered,
metadata   = metadata,
removeVar  = 0.1      # remove bottom 10% variance genes
)
# ── Step 7: Scree plot — how many PCs matter? ────────────────────────────────
scree <- PCAtools::screeplot(
modvar,
components = PCAtools::getComponents(modvar, 1:10),
title      = "Scree plot — variance per PC"
)
p1 <- PCAtools::biplot(
modvar,
x            = "PC1",
y            = "PC2",
colby        = "cell_line",    # colour by cell line
shape        = "timepoint",    # shape by timepoint
legendPosition = "right",
title        = "PCA — PC1 vs PC2",
subtitle     = paste0(
"PC1: ", round(modvar$variance["PC1"], 1), "% variance | ",
"PC2: ", round(modvar$variance["PC2"], 1), "% variance"
),
lab          = NULL,           # no sample labels — too crowded with 156
pointSize    = 3
)
